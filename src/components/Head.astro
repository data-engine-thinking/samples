---
import Default from '@astrojs/starlight/components/Head.astro';
---

<Default />

{/* Restore persisted panel sizes/collapse before paint, to avoid a flash. */}
<script is:inline>
  try {
    var r = document.documentElement,
      s = window.localStorage;
    var lw = s.getItem('det:sidebar-w');
    if (lw) r.style.setProperty('--sl-sidebar-width', lw);
    var rw = s.getItem('det:toc-w');
    if (rw) r.style.setProperty('--det-toc-width', rw);
    /* Swarm hero — only on the home + each chapter's intro page (not the
       reading pages). Per-chapter tint; placeholder colours, confirm vs book. */
    var p = location.pathname.replace(/\/+$/, '');
    var m = p.match(/^\/chapters\/chapter-0*(\d+)$/);
    var sc = m
      ? { '6': 'orange', '8': 'lightgreen', '9': 'yellow', '11': 'darkgreen' }[m[1]]
      : p === ''
        ? 'blue'
        : null;
    if (sc) r.setAttribute('data-swarm', sc);
  } catch (e) {}
</script>

{/* Make the side panels drag-resizable and collapsible. Handles/toggles are
   fixed elements that track each panel edge via the width variables, so they
   never disturb Starlight's sticky panels. */}
<script>
  const root = document.documentElement;
  const K = {
    lw: 'det:sidebar-w',
    rw: 'det:toc-w',
  };
  const clamp = (v: number, lo: number, hi: number) => Math.min(Math.max(v, lo), hi);

  function makeResizer(name: string, selector: string, cssVar: string, key: string, dir: number, min: number, max: number) {
    const handle = document.createElement('div');
    handle.className = 'det-resizer det-resizer-' + name;
    handle.title = 'Drag to resize · double-click to reset';
    document.body.appendChild(handle);
    let x0 = 0;
    let w0 = 0;
    let moved = false;
    const move = (e: PointerEvent) => {
      moved = true;
      const w = clamp(w0 + dir * (e.clientX - x0), min, max);
      root.style.setProperty(cssVar, w + 'px');
    };
    const up = () => {
      document.removeEventListener('pointermove', move);
      document.removeEventListener('pointerup', up);
      document.body.classList.remove('det-resizing');
      if (moved) {
        const v = root.style.getPropertyValue(cssVar);
        if (v) localStorage.setItem(key, v);
      }
    };
    handle.addEventListener('pointerdown', (e) => {
      if (e.button !== 0) return;
      const panel = document.querySelector(selector) as HTMLElement | null;
      if (!panel) return;
      moved = false;
      x0 = e.clientX;
      w0 = panel.getBoundingClientRect().width;
      document.addEventListener('pointermove', move);
      document.addEventListener('pointerup', up);
      document.body.classList.add('det-resizing');
      e.preventDefault();
    });
    handle.addEventListener('dblclick', () => {
      root.style.removeProperty(cssVar);
      localStorage.removeItem(key);
    });
  }

  if (document.querySelector('.sidebar-pane')) {
    makeResizer('sidebar', '.sidebar-pane', '--sl-sidebar-width', K.lw, 1, 176, 460);
  }
  if (document.querySelector('.right-sidebar-container')) {
    makeResizer('toc', '.right-sidebar-container', '--det-toc-width', K.rw, -1, 140, 460);
  }
</script>
